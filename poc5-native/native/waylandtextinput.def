# cinterop for the Wayland text-input-v3 protocol (the IME probe).
#
# Under Wayland the APPLICATION does not talk to IBus. It speaks zwp_text_input_v3 to the COMPOSITOR, and
# the compositor relays to whatever input method is running (via zwp_input_method_v2). Verified on our
# wlroots compositor: it advertises zwp_text_input_manager_v3 and zwp_input_method_manager_v2.
# This is also what JetBrains has to do (JBR-5672).
#
# The headers come from libwayland-dev; text-input-v3-client-protocol.h is generated by wayland-scanner
# from the protocol XML. The generated .c carries the wl_interface tables the protocol needs, and it is
# compiled straight into the binding through the `---` section below (cinterop compiles that C code), so no
# separate C build step is needed.
headers = wayland-client.h text-input-v3-client-protocol.h
package = waylandtext
compilerOpts = -I/usr/include
linkerOpts = -lwayland-client

---

#include "text-input-v3-protocol.c"

// The generated header exposes everything as `static inline` wrappers over wl_proxy_marshal, which cinterop
// does not surface. These thin wrappers give Kotlin a real symbol to call.

static struct zwp_text_input_manager_v3 *ti_manager_bind(struct wl_registry *registry, uint32_t name, uint32_t version) {
    return (struct zwp_text_input_manager_v3 *) wl_registry_bind(registry, name, &zwp_text_input_manager_v3_interface, version);
}

static struct wl_seat *ti_seat_bind(struct wl_registry *registry, uint32_t name, uint32_t version) {
    return (struct wl_seat *) wl_registry_bind(registry, name, &wl_seat_interface, version);
}

static struct zwp_text_input_v3 *ti_get_text_input(struct zwp_text_input_manager_v3 *mgr, struct wl_seat *seat) {
    return zwp_text_input_manager_v3_get_text_input(mgr, seat);
}

static void ti_enable(struct zwp_text_input_v3 *ti)  { zwp_text_input_v3_enable(ti); }
static void ti_disable(struct zwp_text_input_v3 *ti) { zwp_text_input_v3_disable(ti); }
static void ti_commit(struct zwp_text_input_v3 *ti)  { zwp_text_input_v3_commit(ti); }

static void ti_set_cursor_rectangle(struct zwp_text_input_v3 *ti, int32_t x, int32_t y, int32_t w, int32_t h) {
    zwp_text_input_v3_set_cursor_rectangle(ti, x, y, w, h);
}

static int ti_add_listener(struct zwp_text_input_v3 *ti, const struct zwp_text_input_v3_listener *listener, void *data) {
    return zwp_text_input_v3_add_listener(ti, listener, data);
}

static int ti_registry_add_listener(struct wl_registry *registry, const struct wl_registry_listener *listener, void *data) {
    return wl_registry_add_listener(registry, listener, data);
}
